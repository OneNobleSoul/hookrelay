{
  "host": "127.0.0.1",
  "port": 8080,
  "retries": 3,
  "backoff": 0.5,
  "routes": [
    {
      "name": "github-push",
      "match": {
        "path": "/hooks/github",
        "headers": { "X-GitHub-Event": "push" },
        "body_equals": { "ref": "refs/heads/main" }
      },
      "signature": {
        "secret": "change-me",
        "header": "X-Hub-Signature-256",
        "algorithm": "sha256",
        "prefix": "sha256="
      },
      "template": "{{ pusher.name }} pushed to {{ repository.full_name }}",
      "sinks": [
        { "type": "slack", "url": "https://hooks.slack.com/services/XXX/YYY/ZZZ" }
      ]
    },
    {
      "name": "alerts",
      "match": { "path": "/hooks/alerts" },
      "template": "[{{ status }}] {{ title }}",
      "sinks": [
        {
          "type": "ntfy",
          "url": "https://ntfy.sh/my-alerts",
          "options": { "title": "hookrelay", "priority": 4, "tags": ["warning"] }
        },
        { "type": "discord", "url": "https://discord.com/api/webhooks/XXX/YYY" }
      ]
    }
  ]
}
